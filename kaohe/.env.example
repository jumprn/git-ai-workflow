# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string

# Database (SQLite by default, uncomment below for MySQL)
DATABASE_URL=sqlite:///app.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/kaohe?charset=utf8mb4

# Git repos storage directory (absolute path recommended)
REPOS_DIR=C:/ai-coverage-repos

# Scan schedule (cron expression: hour, minute)
SCAN_HOUR=2
SCAN_MINUTE=0
